# ============================================================================
# BankGuard backend — environment variable template
#
# Copy this file to .env and fill in real values.
# .env is git-ignored — it must NEVER be committed. This file (.env.example)
# is committed instead, so the repo documents what's needed without exposing
# actual secrets.
# ============================================================================

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=bankguard

# ----------------------------------------------------------------------------
# JWT
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_value
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_value
JWT_REFRESH_EXPIRY=7d

# ----------------------------------------------------------------------------
# Email (OTP / password reset / notifications)
# ----------------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=change_me
EMAIL_PASSWORD=change_me

# ----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ----------------------------------------------------------------------------
# Cookie signing
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------------------------------------------------------
COOKIE_SECRET=change_me_to_a_long_random_cookie_secret

# ----------------------------------------------------------------------------
# Rate limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ATTEMPTS=10

# ----------------------------------------------------------------------------
# Fraud engine thresholds
# ----------------------------------------------------------------------------
FRAUD_LARGE_TXN_THRESHOLD=5000